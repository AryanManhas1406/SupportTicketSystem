<div class="container py-5 text-center">

  <h1 class="display-4 fw-bold mb-4">
    Support Ticket System
  </h1>

  <p class="lead mb-5">
    User Support Ticket Management Platform
  </p>





  <!-- LOGGED IN USER -->

  <% if(user){ %>

    <div
      class="
        d-flex
        justify-content-center
        gap-3
        flex-wrap
      "
    >




      <!-- NORMAL USER -->

      <% if(user.role !== "Admin"){ %>

        <a
href="/create-ticket"
          class="btn btn-primary btn-lg"
        >
          Create Ticket
        </a>




        <a
          href="/my-tickets"
          class="btn btn-dark btn-lg"
        >
          My Tickets
        </a>




        <a
          href="/blogs/create"
          class="btn btn-success btn-lg"
        >
          Create Blog
        </a>

<a href="/blogs/my-blogs"
class="btn btn-success btn-lg">
MyBlogs</a>


        <a
          href="/blogs"
          class="btn btn-warning btn-lg"
        >
          Approved Blogs
        </a>

      <% } %>






      <!-- ADMIN -->

      <% if(user.role === "Admin"){ %>

        <a
         href="/admin/tickets"
          class="btn btn-dark btn-lg"
        >
          Admin Dashboard
        </a>




        <a
          href="/blogs/admin/all"
          class="btn btn-warning btn-lg"
        >
          All Blogs
        </a>

      <% } %>






      <!-- LOGOUT -->

      <a
        href="/logout"
        class="btn btn-danger btn-lg"
      >
        Logout
      </a>

    </div>






  <!-- GUEST USER -->

  <% } else { %>

    <div
      class="
        d-flex
        justify-content-center
        gap-3
        flex-wrap
      "
    >

      <a
        href="/login"
        class="btn btn-dark btn-lg"
      >
        Login
      </a>




      <a
        href="/signup"
        class="btn btn-warning btn-lg"
      >
        Signup
      </a>

    </div>




    <div class="mt-4">

      <div class="alert alert-info">

        Please login to access
        ticket functionalities

      </div>

    </div>

  <% } %>

</div>