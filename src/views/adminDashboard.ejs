<div class="container py-5">

  <h1 class="mb-5">
    Admin Dashboard
  </h1>

  <div id="ticketContainer"></div>

</div>

<script>

  async function fetchTickets() {

    const token =
      localStorage.getItem("token");

    const response =
      await fetch(
        "/api/admin/tickets",
        {
          headers: {
            Authorization:
              `Bearer ${token}`
          }
        }
      );

    const result =
      await response.json();

    const container =
      document.getElementById(
        "ticketContainer"
      );

    container.innerHTML =
      result.tickets.map(ticket => `

        <div class="card p-4 mb-4">

  <h3>
    ${ticket.title}
  </h3>

  <p>
    ${ticket.description}
  </p>

  <p>
    User:
    ${ticket.user.name}
  </p>

  <p>
    Current Status:
    <strong>
      ${ticket.status}
    </strong>
  </p>

  <textarea
    id="reply-${ticket._id}"
    class="form-control mb-3"
    placeholder="Write reply..."
  ></textarea>

  <select
    id="status-${ticket._id}"
    class="form-select mb-3"
  >

    <option value="Open">
      Open
    </option>

    <option value="Pending">
      Pending
    </option>

    <option value="Resolved">
      Resolved
    </option>

  </select>

  <button
    class="btn btn-primary"

    onclick="sendReply(
      '${ticket._id}'
    )"
  >
    Reply & Update Status
  </button>

</div>

      `).join("");
  }

  async function sendReply(ticketId) {

  const token =
    localStorage.getItem("token");

  const message =
    document.getElementById(
      `reply-${ticketId}`
    ).value;

  const status =
    document.getElementById(
      `status-${ticketId}`
    ).value;

  const response =
    await fetch(

      `/api/tickets/${ticketId}/reply`,

      {

        method: "POST",

        headers: {

          "Content-Type":
            "application/json",

          Authorization:
            `Bearer ${token}`

        },

        body: JSON.stringify({

          message,

          status

        })

      }
    );

  const result =
    await response.json();

  alert(
    result.message ||
    "Updated successfully"
  );

  location.reload();
}
  fetchTickets();

</script>