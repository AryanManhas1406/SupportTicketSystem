<div class="container py-5">

  <h1 class="mb-4">
    My Tickets
  </h1>






  <% if(tickets.length === 0){ %>

    <div class="alert alert-info">

      No tickets found

    </div>

  <% } %>








  <% tickets.forEach(ticket => { %>

    <div
      class="card shadow-sm mb-4 border-0"
    >

      <div class="card-body">




        <div
          class="
            d-flex
            justify-content-between
            align-items-center
          "
        >

          <h4>

            <%= ticket.title %>

          </h4>





          <span
            class="
              badge
              bg-primary
            "
          >

            <%= ticket.priority %>

          </span>

        </div>








        <p class="mt-3">

          <%= ticket.description %>

        </p>








        <div
          class="
            d-flex
            justify-content-between
          "
        >

          <span
            class="
              badge
              bg-success
            "
          >

            <%= ticket.status %>

          </span>






          <small>

            <%= new Date(
               ticket.createdAt
            ).toLocaleString() %>

          </small>

        </div>

      </div>

    </div>

  <% }) %>

</div>