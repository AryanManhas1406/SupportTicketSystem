<!DOCTYPE html>
<html lang="en">

<head>

   <meta charset="UTF-8">

   <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
   >

   <title>
      Approved Blogs
   </title>


   <!-- bootstrap -->

   <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
   >

</head>

<body>


   <!-- navbar -->




   <div class="container mt-5">


      <div class="text-center mb-5">

         <h1 class="fw-bold">

            Approved Blogs

         </h1>

         <p class="text-muted">

            Read blogs approved by admin

         </p>

      </div>





      <% if(blogs.length === 0){ %>

         <div class="alert alert-info text-center">

            No approved blogs available.

         </div>

      <% } %>






      <div class="row">


         <% blogs.forEach(blog => { %>

            <div class="col-md-6 mb-4">


               <div class="card shadow h-100">


                  <div class="card-body">


                     <!-- title -->

                     <h3 class="card-title">

                        <%= blog.title %>

                     </h3>



                     <!-- author -->

                     <p class="text-muted">

                        By
                        <strong>

                           <%= blog.user?.name %>

                        </strong>

                     </p>



                     <!-- description -->

                     <p class="card-text">

                        <%= blog.description.substring(0,150) %>...

                     </p>




                     <!-- status -->

                     <span class="badge bg-success">

                        Approved

                     </span>




                     <!-- read more -->

                     <div class="mt-3">

                        <a
                           href="/blogs/<%= blog._id %>"
                           class="btn btn-dark"
                        >

                           Read More

                        </a>

                     </div>


                  </div>

               </div>

            </div>

         <% }) %>


      </div>

   </div>

</body>

</html>