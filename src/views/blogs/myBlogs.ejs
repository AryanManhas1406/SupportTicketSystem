<!DOCTYPE html>
<html lang="en">

<head>

   <meta charset="UTF-8">

   <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
   >

   <title>
      My Blogs
   </title>


   <!-- bootstrap -->

   <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
   >

</head>

<body>


   <!-- navbar -->





   <div class="container mt-5">


      <!-- heading -->

      <div class="d-flex justify-content-between align-items-center mb-4">


         <div>

            <h1 class="fw-bold">

               My Blogs

            </h1>

            <p class="text-muted">

               Manage your blogs

            </p>

         </div>




         <!-- create button -->

         <a
            href="/blogs/create"
            class="btn btn-dark"
         >

            Create Blog

         </a>

      </div>






      <% if(blogs.length === 0){ %>

         <div class="alert alert-info">

            No blogs created yet.

         </div>

      <% } %>







      <div class="row">


         <% blogs.forEach(blog => { %>

            <div class="col-md-6 mb-4">


               <div class="card shadow h-100">


                  <div class="card-body">


                     <!-- title -->

                     <h3>

                        <%= blog.title %>

                     </h3>





                     <!-- description -->

                     <p>

                        <%= blog.description.substring(0,150) %>...

                     </p>





                     <!-- status -->

                     <p>

                        Status:


                        <% if(blog.status === "approved"){ %>

                           <span class="badge bg-success">

                              Approved

                           </span>

                        <% } else if(blog.status === "rejected"){ %>

                           <span class="badge bg-danger">

                              Rejected

                           </span>

                        <% } else { %>

                           <span class="badge bg-warning text-dark">

                              Pending

                           </span>

                        <% } %>

                     </p>






                     <!-- buttons -->

                     <div class="d-flex gap-2 mt-3">


                        <!-- edit -->

                        <a
                           href="/blogs/edit/<%= blog._id %>"
                           class="btn btn-primary"
                        >

                           Edit

                        </a>





                        <!-- delete -->

                        <form
                           action="/blogs/delete/<%= blog._id %>"
                           method="POST"
                        >

                           <button
                              type="submit"
                              class="btn btn-danger"
                           >

                              Delete

                           </button>

                        </form>


                     </div>


                  </div>

               </div>

            </div>

         <% }) %>


      </div>

   </div>

</body>

</html>